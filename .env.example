# Pelican Libertex Social — environment template.
# Copy to .env, fill in your own values, then run install.ps1.
# .env is in .gitignore — never commit your real credentials.

# ---- Libertex Social account ----
# Used by the headless-Chrome refresher (refresher.js) to log in and
# rotate the OAuth access token automatically. Use your own account.
LIBERTEX_EMAIL=your-email@example.com
LIBERTEX_PASSWORD=your-password-here

# ---- ngrok tunnel ----
# Free account at https://dashboard.ngrok.com/signup
# Get authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Your reserved free static domain (https://dashboard.ngrok.com/domains).
# Free tier gives one static *.ngrok-free.dev subdomain. Paste here without https://
# e.g. NGROK_DOMAIN=fluffy-tiger-1234.ngrok-free.dev
NGROK_DOMAIN=

# ---- Runtime (do not edit by hand) ----
# refresher.js writes ACCESS_TOKEN/EXPIRES_AT here on each rotation.
# Leave empty on first run; the refresher fills them in within ~30 seconds.
ACCESS_TOKEN=
EXPIRES_AT=
